<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DeskBorder.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnDashboardPageLoaded"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Padding="24" Spacing="20">
            <StackPanel Spacing="8">
                <TextBlock
                    x:Uid="DashboardPage_TitleTextBlock"
                    Style="{ThemeResource TitleTextBlockStyle}"
                    Text="DeskBorder" />
                <TextBlock
                    x:Uid="DashboardPage_DescriptionTextBlock"
                    Text="실시간 상태, 빠른 토글, Navigator 및 감시 기반을 한 화면에서 확인할 수 있습니다."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <InfoBar
                x:Name="DashboardStatusInfoBar"
                IsClosable="False"
                IsOpen="False"
                Severity="Error" />

            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="12">
                        <TextBlock
                            x:Uid="DashboardPage_ServiceStatusTitleTextBlock"
                            FontWeight="SemiBold"
                            Text="서비스 상태" />
                        <TextBlock x:Name="RuntimeStatusTextBlock" TextWrapping="WrapWholeWords" />
                        <TextBlock
                            x:Name="MonitoringStatusTextBlock"
                            Opacity="0.72"
                            TextWrapping="WrapWholeWords" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button
                                x:Name="ToggleRuntimeButton"
                                Click="OnToggleRuntimeButtonClicked"
                                Content="DeskBorder 사용 안 함" />
                            <Button
                                x:Uid="DashboardPage_OpenSettingsButton"
                                Click="OnOpenSettingsButtonClicked"
                                Content="세부 설정 열기" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="12">
                        <TextBlock
                            x:Uid="DashboardPage_QuickTogglesTitleTextBlock"
                            FontWeight="SemiBold"
                            Text="빠른 토글" />
                        <ToggleSwitch
                            x:Name="LaunchOnStartupToggleSwitch"
                            x:Uid="DashboardPage_LaunchOnStartupToggleSwitch"
                            Header="시스템 시작 시 자동 실행"
                            Toggled="OnLaunchOnStartupToggleSwitchToggled" />
                        <ToggleSwitch
                            x:Name="StoreUpdateCheckToggleSwitch"
                            x:Uid="DashboardPage_StoreUpdateCheckToggleSwitch"
                            Header="스토어 업데이트 확인"
                            Toggled="OnStoreUpdateCheckToggleSwitchToggled" />
                        <TextBlock
                            x:Name="GeneralSettingsSummaryTextBlock"
                            Opacity="0.72"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="1"
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="12">
                        <TextBlock
                            x:Uid="DashboardPage_HotkeyTitleTextBlock"
                            FontWeight="SemiBold"
                            Text="단축키 구성" />
                        <TextBlock x:Name="HotkeySummaryTextBlock" TextWrapping="WrapWholeWords" />
                        <TextBlock
                            x:Name="ModifierSummaryTextBlock"
                            Opacity="0.72"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="12">
                        <TextBlock
                            x:Uid="DashboardPage_NavigatorTitleTextBlock"
                            FontWeight="SemiBold"
                            Text="Navigator 및 감시" />
                        <TextBlock x:Name="NavigatorSummaryTextBlock" TextWrapping="WrapWholeWords" />
                        <TextBlock
                            x:Name="DisplaySummaryTextBlock"
                            Opacity="0.72"
                            TextWrapping="WrapWholeWords" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button
                                x:Uid="DashboardPage_ToggleNavigatorButton"
                                Click="OnToggleNavigatorButtonClicked"
                                Content="Navigator 표시" />
                            <Button
                                x:Uid="DashboardPage_OpenNavigatorSettingsButton"
                                Click="OnOpenSettingsFromNavigatorButtonClicked"
                                Content="Navigator 설정" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
