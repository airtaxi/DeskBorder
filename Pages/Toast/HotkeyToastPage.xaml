<?xml version="1.0" encoding="utf-8" ?>
<toast:ToastPageBase
    x:Class="DeskBorder.Pages.Toast.HotkeyToastPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toast="using:DeskBorder.Pages.Toast"
    mc:Ignorable="d">
    <Grid Background="Transparent">
        <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel VerticalAlignment="Center" Spacing="8">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{x:Bind PresentationOptions.Title}"
                    TextWrapping="NoWrap" />

                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind PresentationOptions.Message}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>
    </Grid>
</toast:ToastPageBase>
