<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DeskBorder.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:DeskBorder.ViewModels"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="SelectionOptionTextTemplate" x:DataType="vm:SelectionOptionBase">
            <TextBlock Text="{x:Bind DisplayText}" />
        </DataTemplate>
        <Style x:Key="SectionHelpButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style x:Key="SectionTeachingTipContentTextBlockStyle" TargetType="TextBlock">
            <Setter Property="MaxWidth" Value="420" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>
    </Page.Resources>
    <Grid Padding="24" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Uid="SettingsPage_TitleTextBlock"
            Grid.Row="0"
            Style="{ThemeResource TitleTextBlockStyle}"
            Text="설정" />

        <InfoBar
            x:Name="SettingsStatusInfoBar"
            Grid.Row="1"
            IsClosable="False"
            IsOpen="False"
            Severity="Error" />

        <ScrollViewer Grid.Row="2">
            <StackPanel Spacing="20">
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="6">
                                <TextBlock
                                    x:Uid="SettingsPage_GeneralSectionTitleTextBlock"
                                    FontWeight="SemiBold"
                                    Text="일반" />
                                <TextBlock
                                    x:Uid="SettingsPage_GeneralSectionDescriptionTextBlock"
                                    Text="앱 전반 동작, 시작 옵션, 업데이트 확인 정책을 설정합니다."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Grid
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                                <Button
                                    x:Name="GeneralSectionHelpButton"
                                    Click="OnSectionHelpButtonClicked"
                                    Style="{StaticResource SectionHelpButtonStyle}"
                                    Tag="{x:Bind GeneralSectionTeachingTip}">
                                    <FontIcon Glyph="&#xE9CE;" />
                                </Button>
                                <TeachingTip
                                    x:Name="GeneralSectionTeachingTip"
                                    x:Uid="SettingsPage_GeneralSectionTeachingTip"
                                    Title="일반 설정 안내"
                                    Closed="OnSectionTeachingTipClosed"
                                    IsLightDismissEnabled="True"
                                    PreferredPlacement="BottomLeft"
                                    ShouldConstrainToRootBounds="False"
                                    Target="{x:Bind GeneralSectionHelpButton}">
                                    <TeachingTip.Content>
                                        <TextBlock
                                            x:Uid="SettingsPage_GeneralSectionTeachingTipContentTextBlock"
                                            Style="{StaticResource SectionTeachingTipContentTextBlockStyle}"
                                            Text="일반 섹션의 각 설정 설명" />
                                    </TeachingTip.Content>
                                </TeachingTip>
                            </Grid>
                        </Grid>

                        <ToggleSwitch
                            x:Name="DeskBorderEnabledToggleSwitch"
                            x:Uid="SettingsPage_DeskBorderEnabledToggleSwitch"
                            Header="DeskBorder 사용"
                            IsOn="{x:Bind ViewModel.IsDeskBorderEnabled, Mode=TwoWay}"
                            Toggled="OnSettingToggleSwitchToggled" />

                        <ToggleSwitch
                            x:Name="LaunchOnStartupToggleSwitch"
                            x:Uid="SettingsPage_LaunchOnStartupToggleSwitch"
                            Header="시스템 시작 시 자동 실행"
                            IsOn="{x:Bind ViewModel.IsLaunchOnStartupEnabled, Mode=TwoWay}"
                            Toggled="OnSettingToggleSwitchToggled" />

                        <ToggleSwitch
                            x:Name="StoreUpdateCheckToggleSwitch"
                            x:Uid="SettingsPage_StoreUpdateCheckToggleSwitch"
                            Header="스토어 업데이트 확인"
                            IsOn="{x:Bind ViewModel.IsStoreUpdateCheckEnabled, Mode=TwoWay}"
                            Toggled="OnSettingToggleSwitchToggled" />

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="8">
                                <TextBlock
                                    x:Uid="SettingsPage_StoreUpdateStatusTitleTextBlock"
                                    FontWeight="SemiBold"
                                    Text="업데이트 확인" />
                                <TextBlock
                                    x:Name="StoreUpdateStatusTextBlock"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="WrapWholeWords" />
                                <InfoBar
                                    x:Name="StoreUpdateVersionInfoBar"
                                    IsClosable="False"
                                    IsOpen="True"
                                    Severity="Informational" />
                            </StackPanel>
                            <Button
                                x:Name="CheckStoreUpdateButton"
                                x:Uid="SettingsPage_CheckStoreUpdateButton"
                                Grid.Column="1"
                                MinWidth="120"
                                Margin="0,0,0,10"
                                VerticalAlignment="Bottom"
                                Click="OnCheckStoreUpdateButtonClicked"
                                Content="확인하기" />
                        </Grid>

                        <ComboBox
                            x:Name="MultiDisplayBehaviorComboBox"
                            x:Uid="SettingsPage_MultiDisplayBehaviorComboBox"
                            Header="다중 디스플레이 동작"
                            ItemTemplate="{StaticResource SelectionOptionTextTemplate}"
                            ItemsSource="{x:Bind ViewModel.MultiDisplayBehaviorOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedMultiDisplayBehaviorOption, Mode=TwoWay}"
                            SelectionChanged="OnSettingSelectionChanged" />

                        <ComboBox
                            x:Name="ApplicationThemePreferenceComboBox"
                            x:Uid="SettingsPage_ApplicationThemePreferenceComboBox"
                            Header="앱 테마"
                            ItemTemplate="{StaticResource SelectionOptionTextTemplate}"
                            ItemsSource="{x:Bind ViewModel.ApplicationThemePreferenceOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedApplicationThemePreferenceOption, Mode=TwoWay}"
                            SelectionChanged="OnSettingSelectionChanged" />

                        <ComboBox
                            x:Name="AppLanguagePreferenceComboBox"
                            x:Uid="SettingsPage_AppLanguagePreferenceComboBox"
                            Header="앱 언어"
                            ItemTemplate="{StaticResource SelectionOptionTextTemplate}"
                            ItemsSource="{x:Bind ViewModel.AppLanguagePreferenceOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedAppLanguagePreferenceOption, Mode=TwoWay}"
                            SelectionChanged="OnSettingSelectionChanged" />
                    </StackPanel>
                </Border>

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="6">
                                <TextBlock
                                    x:Uid="SettingsPage_EdgeSectionTitleTextBlock"
                                    FontWeight="SemiBold"
                                    Text="가장자리 및 자동 정리" />
                                <TextBlock
                                    x:Uid="SettingsPage_EdgeSectionDescriptionTextBlock"
                                    Text="다중 디스플레이 환경, 자동 삭제 정책, 가장자리 무시 영역을 설정합니다."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Grid
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                                <Button
                                    x:Name="EdgeSectionHelpButton"
                                    Click="OnSectionHelpButtonClicked"
                                    Style="{StaticResource SectionHelpButtonStyle}"
                                    Tag="{x:Bind EdgeSectionTeachingTip}">
                                    <FontIcon Glyph="&#xE9CE;" />
                                </Button>
                                <TeachingTip
                                    x:Name="EdgeSectionTeachingTip"
                                    x:Uid="SettingsPage_EdgeSectionTeachingTip"
                                    Title="가장자리 및 자동 정리 안내"
                                    Closed="OnSectionTeachingTipClosed"
                                    IsLightDismissEnabled="True"
                                    PreferredPlacement="BottomLeft"
                                    ShouldConstrainToRootBounds="False"
                                    Target="{x:Bind EdgeSectionHelpButton}">
                                    <TeachingTip.Content>
                                        <TextBlock
                                            x:Uid="SettingsPage_EdgeSectionTeachingTipContentTextBlock"
                                            Style="{StaticResource SectionTeachingTipContentTextBlockStyle}"
                                            Text="가장자리 및 자동 정리 섹션의 각 설정 설명" />
                                    </TeachingTip.Content>
                                </TeachingTip>
                            </Grid>
                        </Grid>

                        <ToggleSwitch
                            x:Name="AutoDeleteToggleSwitch"
                            x:Uid="SettingsPage_AutoDeleteToggleSwitch"
                            Header="빈 데스크톱 자동 삭제"
                            IsOn="{x:Bind ViewModel.IsAutoDeleteEnabled, Mode=TwoWay}"
                            Toggled="OnSettingToggleSwitchToggled" />

                        <ToggleSwitch
                            x:Name="AutoDeleteWarningToggleSwitch"
                            x:Uid="SettingsPage_AutoDeleteWarningToggleSwitch"
                            Header="삭제 경고 표시"
                            IsEnabled="{x:Bind ViewModel.IsAutoDeleteEnabled, Mode=OneWay}"
                            IsOn="{x:Bind ViewModel.IsAutoDeleteWarningEnabled, Mode=TwoWay}"
                            Toggled="OnSettingToggleSwitchToggled" />

                        <ToggleSwitch
                            x:Name="AutoDeleteCompletionToastToggleSwitch"
                            x:Uid="SettingsPage_AutoDeleteCompletionToastToggleSwitch"
                            Header="자동 삭제 완료 알림 표시"
                            IsEnabled="{x:Bind ViewModel.IsAutoDeleteCompletionToastToggleEnabled, Mode=OneWay}"
                            IsOn="{x:Bind ViewModel.IsAutoDeleteCompletionToastEnabled, Mode=TwoWay}"
                            Toggled="OnSettingToggleSwitchToggled" />

                        <TextBlock
                            x:Uid="SettingsPage_AutoDeleteCompletionToastDescriptionTextBlock"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="삭제 경고를 끈 경우에만 사용할 수 있습니다. 빈 데스크톱이 바로 삭제되었을 때 ToastWindow로 결과를 알려줍니다."
                            TextWrapping="WrapWholeWords" />

                        <ToggleSwitch
                            x:Name="DesktopEdgeAdditionalTriggerDistanceToggleSwitch"
                            x:Uid="SettingsPage_DesktopEdgeAdditionalTriggerDistanceToggleSwitch"
                            Header="가장자리 추가 이동 거리 사용"
                            IsOn="{x:Bind ViewModel.IsDesktopEdgeAdditionalTriggerDistanceEnabled, Mode=TwoWay}"
                            Toggled="OnSettingToggleSwitchToggled" />

                        <Border
                            Padding="12"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            CornerRadius="10"
                            Visibility="{x:Bind GetDesktopEdgeAdditionalTriggerDistanceVisibility(ViewModel.IsDesktopEdgeAdditionalTriggerDistanceEnabled), Mode=OneWay}">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    x:Uid="SettingsPage_DesktopEdgeAdditionalTriggerDistanceDescriptionTextBlock"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="가장자리에 닿은 뒤에도 바깥쪽으로 마우스를 더 민 거리가 현재 모니터 너비의 지정 비율 이상일 때만 전환 또는 생성합니다."
                                    TextWrapping="WrapWholeWords" />
                                <NumberBox
                                    x:Name="DesktopEdgeAdditionalTriggerDistancePercentageNumberBox"
                                    x:Uid="SettingsPage_DesktopEdgeAdditionalTriggerDistancePercentageNumberBox"
                                    Header="추가 이동 거리 (%)"
                                    Maximum="50"
                                    Minimum="0.1"
                                    SmallChange="0.5"
                                    SpinButtonPlacementMode="Inline"
                                    Value="{x:Bind ViewModel.DesktopEdgeAdditionalTriggerDistancePercentage, Mode=TwoWay}"
                                    ValueChanged="OnSettingNumberBoxValueChanged" />
                            </StackPanel>
                        </Border>

                        <Border
                            Padding="12"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            CornerRadius="10"
                            Visibility="{x:Bind GetAutoDeleteWarningTimeoutVisibility(ViewModel.IsAutoDeleteEnabled, ViewModel.IsAutoDeleteWarningEnabled), Mode=OneWay}">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    x:Uid="SettingsPage_AutoDeleteWarningTimeoutDescriptionTextBlock"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="삭제 경고가 켜져 있을 때 실행 취소를 기다리는 시간을 조절합니다."
                                    TextWrapping="WrapWholeWords" />
                                <NumberBox
                                    x:Name="AutoDeleteWarningTimeoutSecondsNumberBox"
                                    x:Uid="SettingsPage_AutoDeleteWarningTimeoutSecondsNumberBox"
                                    Header="삭제 경고 타임아웃 (초)"
                                    Maximum="10"
                                    Minimum="0.5"
                                    SmallChange="0.5"
                                    SpinButtonPlacementMode="Inline"
                                    ValueChanged="OnSettingNumberBoxValueChanged"
                                    Value="{x:Bind ViewModel.AutoDeleteWarningTimeoutSeconds, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <NumberBox
                                x:Name="TopDesktopEdgeIgnorePercentageNumberBox"
                                x:Uid="SettingsPage_TopDesktopEdgeIgnorePercentageNumberBox"
                                Header="상단 무시 영역 (%)"
                                Maximum="49"
                                Minimum="0"
                                SmallChange="1"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="OnSettingNumberBoxValueChanged"
                                Value="{x:Bind ViewModel.TopDesktopEdgeIgnorePercentage, Mode=TwoWay}" />

                            <NumberBox
                                x:Name="BottomDesktopEdgeIgnorePercentageNumberBox"
                                x:Uid="SettingsPage_BottomDesktopEdgeIgnorePercentageNumberBox"
                                Grid.Column="1"
                                Header="하단 무시 영역 (%)"
                                Maximum="49"
                                Minimum="0"
                                SmallChange="1"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="OnSettingNumberBoxValueChanged"
                                Value="{x:Bind ViewModel.BottomDesktopEdgeIgnorePercentage, Mode=TwoWay}" />
                        </Grid>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Padding="12"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="10">
                                <StackPanel Spacing="10">
                                    <TextBlock
                                        x:Uid="SettingsPage_SwitchDesktopModifierTitleTextBlock"
                                        FontWeight="SemiBold"
                                        Text="데스크톱 전환 보조키" />
                                    <CheckBox
                                        x:Uid="SettingsPage_SwitchDesktopControlCheckBox"
                                        Click="OnModifierSelectionCheckBoxClicked"
                                        Content="Ctrl"
                                        Tag="SwitchDesktopModifierSelection"
                                        IsChecked="{x:Bind ViewModel.SwitchDesktopModifierSelection.IsControlEnabled, Mode=TwoWay}" />
                                    <CheckBox
                                        x:Uid="SettingsPage_SwitchDesktopShiftCheckBox"
                                        Click="OnModifierSelectionCheckBoxClicked"
                                        Content="Shift"
                                        Tag="SwitchDesktopModifierSelection"
                                        IsChecked="{x:Bind ViewModel.SwitchDesktopModifierSelection.IsShiftEnabled, Mode=TwoWay}" />
                                    <CheckBox
                                        x:Uid="SettingsPage_SwitchDesktopAltCheckBox"
                                        Click="OnModifierSelectionCheckBoxClicked"
                                        Content="Alt"
                                        Tag="SwitchDesktopModifierSelection"
                                        IsChecked="{x:Bind ViewModel.SwitchDesktopModifierSelection.IsAlternateEnabled, Mode=TwoWay}" />
                                    <CheckBox
                                        x:Uid="SettingsPage_SwitchDesktopWindowsCheckBox"
                                        Click="OnModifierSelectionCheckBoxClicked"
                                        Content="Windows"
                                        Tag="SwitchDesktopModifierSelection"
                                        IsChecked="{x:Bind ViewModel.SwitchDesktopModifierSelection.IsWindowsEnabled, Mode=TwoWay}" />
                                </StackPanel>
                            </Border>

                            <Grid
                                Grid.Column="1"
                                Padding="12"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="10">
                                <ToggleSwitch
                                    x:Uid="SettingsPage_CreateDesktopEnabledToggleSwitch"
                                    MinWidth="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    IsOn="{x:Bind ViewModel.IsDesktopCreationEnabled, Mode=TwoWay}"
                                    Toggled="OnSettingToggleSwitchToggled" />
                                <StackPanel Spacing="10">
                                    <TextBlock
                                        x:Uid="SettingsPage_CreateDesktopModifierTitleTextBlock"
                                        FontWeight="SemiBold"
                                        Text="데스크톱 생성 보조키" />
                                    <Frame IsEnabled="{x:Bind ViewModel.IsDesktopCreationEnabled, Mode=OneWay}">
                                        <StackPanel Spacing="10">
                                            <CheckBox
                                                x:Uid="SettingsPage_CreateDesktopControlCheckBox"
                                                Click="OnModifierSelectionCheckBoxClicked"
                                                Content="Ctrl"
                                                Tag="CreateDesktopModifierSelection"
                                                IsChecked="{x:Bind ViewModel.CreateDesktopModifierSelection.IsControlEnabled, Mode=TwoWay}" />
                                            <CheckBox
                                                x:Uid="SettingsPage_CreateDesktopShiftCheckBox"
                                                Click="OnModifierSelectionCheckBoxClicked"
                                                Content="Shift"
                                                Tag="CreateDesktopModifierSelection"
                                                IsChecked="{x:Bind ViewModel.CreateDesktopModifierSelection.IsShiftEnabled, Mode=TwoWay}" />
                                            <CheckBox
                                                x:Uid="SettingsPage_CreateDesktopAltCheckBox"
                                                Click="OnModifierSelectionCheckBoxClicked"
                                                Content="Alt"
                                                Tag="CreateDesktopModifierSelection"
                                                IsChecked="{x:Bind ViewModel.CreateDesktopModifierSelection.IsAlternateEnabled, Mode=TwoWay}" />
                                            <CheckBox
                                                x:Uid="SettingsPage_CreateDesktopWindowsCheckBox"
                                                Click="OnModifierSelectionCheckBoxClicked"
                                                Content="Windows"
                                                Tag="CreateDesktopModifierSelection"
                                                IsChecked="{x:Bind ViewModel.CreateDesktopModifierSelection.IsWindowsEnabled, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Frame>
                                </StackPanel>
                            </Grid>

                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="6">
                                <TextBlock
                                    x:Uid="SettingsPage_HotkeysSectionTitleTextBlock"
                                    FontWeight="SemiBold"
                                    Text="전역 단축키" />
                                <TextBlock
                                    x:Uid="SettingsPage_HotkeysSectionDescriptionTextBlock"
                                    Text="DeskBorder, 창 이동, Navigator를 직접 제어하는 단축키를 설정합니다."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Grid
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                                <Button
                                    x:Name="HotkeysSectionHelpButton"
                                    Click="OnSectionHelpButtonClicked"
                                    Style="{StaticResource SectionHelpButtonStyle}"
                                    Tag="{x:Bind HotkeysSectionTeachingTip}">
                                    <FontIcon Glyph="&#xE9CE;" />
                                </Button>
                                <TeachingTip
                                    x:Name="HotkeysSectionTeachingTip"
                                    x:Uid="SettingsPage_HotkeysSectionTeachingTip"
                                    Title="전역 단축키 안내"
                                    Closed="OnSectionTeachingTipClosed"
                                    IsLightDismissEnabled="True"
                                    PreferredPlacement="BottomLeft"
                                    ShouldConstrainToRootBounds="False"
                                    Target="{x:Bind HotkeysSectionHelpButton}">
                                    <TeachingTip.Content>
                                        <TextBlock
                                            x:Uid="SettingsPage_HotkeysSectionTeachingTipContentTextBlock"
                                            Style="{StaticResource SectionTeachingTipContentTextBlockStyle}"
                                            Text="전역 단축키 섹션의 각 설정 설명" />
                                    </TeachingTip.Content>
                                </TeachingTip>
                            </Grid>
                        </Grid>

                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel
                                    Grid.Row="0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Ellipse
                                        Width="10"
                                        Height="10"
                                        VerticalAlignment="Center"
                                        Fill="{x:Bind GetKeyboardShortcutValidationForegroundBrush(ViewModel.ToggleDeskBorderEnabledHotkeyValidationState), Mode=OneWay}" />
                                    <TextBlock Foreground="{x:Bind GetKeyboardShortcutValidationForegroundBrush(ViewModel.ToggleDeskBorderEnabledHotkeyValidationState), Mode=OneWay}" Text="{x:Bind GetKeyboardShortcutValidationText(ViewModel.ToggleDeskBorderEnabledHotkeyValidationState), Mode=OneWay}" />
                                </StackPanel>
                                <Grid Grid.Row="1" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleSwitch
                                        x:Uid="SettingsPage_ToggleDeskBorderHotkeyToggleSwitch"
                                        Grid.Column="0"
                                        Margin="0,-8"
                                        VerticalAlignment="Center"
                                        Header="DeskBorder 사용 토글 단축키"
                                        IsOn="{x:Bind ViewModel.ToggleDeskBorderEnabledHotkeyEditor.IsEnabled, Mode=TwoWay}"
                                        Toggled="OnSettingToggleSwitchToggled" />
                                    <ComboBox
                                        x:Uid="SettingsPage_ToggleDeskBorderHotkeyKeyComboBox"
                                        Grid.Column="1"
                                        VerticalAlignment="Top"
                                        Header="기본 키"
                                        IsEnabled="{x:Bind ViewModel.ToggleDeskBorderEnabledHotkeyEditor.IsEnabled, Mode=OneWay}"
                                        ItemTemplate="{StaticResource SelectionOptionTextTemplate}"
                                        ItemsSource="{x:Bind ViewModel.ToggleDeskBorderEnabledHotkeyEditor.VirtualKeyOptions, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.ToggleDeskBorderEnabledHotkeyEditor.SelectedVirtualKeyOption, Mode=TwoWay}"
                                        SelectionChanged="OnSettingSelectionChanged" />
                                    <StackPanel
                                        Grid.Column="2"
                                        VerticalAlignment="Top"
                                        Spacing="10">
                                        <TextBlock
                                            x:Uid="SettingsPage_ToggleDeskBorderHotkeyModifierTextBlock"
                                            Foreground="{x:Bind GetHotkeyLabelForegroundBrush(ViewModel.ToggleDeskBorderEnabledHotkeyEditor.IsEnabled), Mode=OneWay}"
                                            Text="보조 키" />
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <CheckBox
                                                x:Uid="SettingsPage_ToggleDeskBorderHotkeyControlCheckBox"
                                                Click="OnModifierSelectionCheckBoxClicked"
                                                Content="Ctrl"
                                                Tag="ToggleDeskBorderEnabledHotkeyEditor"
                                                IsChecked="{x:Bind ViewModel.ToggleDeskBorderEnabledHotkeyEditor.RequiredKeyboardModifierSelection.IsControlEnabled, Mode=TwoWay}"
                                                IsEnabled="{x:Bind ViewModel.ToggleDeskBorderEnabledHotkeyEditor.IsEnabled, Mode=OneWay}" />
                                            <CheckBox
                                                x:Uid="SettingsPage_ToggleDeskBorderHotkeyShiftCheckBox"
                                                Click="OnModifierSelectionCheckBoxClicked"
                                                Content="Shift"
                                                Tag="ToggleDeskBorderEnabledHotkeyEditor"
                                                IsChecked="{x:Bind ViewModel.ToggleDeskBorderEnabledHotkeyEditor.RequiredKeyboardModifierSelection.IsShiftEnabled, Mode=TwoWay}"
                                                IsEnabled="{x:Bind ViewModel.ToggleDeskBorderEnabledHotkeyEditor.IsEnabled, Mode=OneWay}" />
                                            <CheckBox
                                                x:Uid="SettingsPage_ToggleDeskBorderHotkeyAltCheckBox"
                                                Click="OnModifierSelectionCheckBoxClicked"
                                                Content="Alt"
                                                Tag="ToggleDeskBorderEnabledHotkeyEditor"
                                                IsChecked="{x:Bind ViewModel.ToggleDeskBorderEnabledHotkeyEditor.RequiredKeyboardModifierSelection.IsAlternateEnabled, Mode=TwoWay}"
                                                IsEnabled="{x:Bind ViewModel.ToggleDeskBorderEnabledHotkeyEditor.IsEnabled, Mode=OneWay}" />
                                            <CheckBox
                                                x:Uid="SettingsPage_ToggleDeskBorderHotkeyWindowsCheckBox"
                                                Click="OnModifierSelectionCheckBoxClicked"
                                                Content="Windows"
                                                Tag="ToggleDeskBorderEnabledHotkeyEditor"
                                                IsChecked="{x:Bind ViewModel.ToggleDeskBorderEnabledHotkeyEditor.RequiredKeyboardModifierSelection.IsWindowsEnabled, Mode=TwoWay}"
                                                IsEnabled="{x:Bind ViewModel.ToggleDeskBorderEnabledHotkeyEditor.IsEnabled, Mode=OneWay}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>

                            <Grid Grid.Row="1" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
