                                <TeachingTip
                                    x:Name="ImportExportSectionTeachingTip"
                                    x:Uid="SettingsPage_ImportExportSectionTeachingTip"
                                    Title="설정 불러오기 및 내보내기 안내"
                                    Closed="OnSectionTeachingTipClosed"
                                    IsLightDismissEnabled="True"
                                    PreferredPlacement="TopLeft"
                                    ShouldConstrainToRootBounds="False"
                                    Target="{x:Bind ImportExportSectionHelpButton}">
                                    <TeachingTip.Content>
                                        <TextBlock
                                            x:Uid="SettingsPage_ImportExportSectionTeachingTipContentTextBlock"
                                            Style="{StaticResource SectionTeachingTipContentTextBlockStyle}"
                                            Text="설정 불러오기 및 내보내기 섹션의 각 설정 설명" />
                                    </TeachingTip.Content>
                                </TeachingTip>
                            </Grid>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button
                                x:Name="ExportSettingsButton"
                                x:Uid="SettingsPage_ExportSettingsButton"
                                Click="OnExportSettingsButtonClicked"
                                Content="설정 내보내기" />
                            <Button
                                x:Name="ImportSettingsButton"
                                x:Uid="SettingsPage_ImportSettingsButton"
                                Click="OnImportSettingsButtonClicked"
                                Content="설정 불러오기" />
                        </StackPanel>

                        <InfoBar
                            x:Name="SettingsImportExportInfoBar"
                            IsClosable="False"
                            IsOpen="False"
                            Severity="Informational" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
