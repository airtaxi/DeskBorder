                                                Content="Shift"
                                                IsChecked="{x:Bind ViewModel.MoveFocusedWindowToPreviousDesktopHotkeyEditor.RequiredKeyboardModifierSelection.IsShiftEnabled, Mode=TwoWay}"
                                                IsEnabled="{x:Bind ViewModel.MoveFocusedWindowToPreviousDesktopHotkeyEditor.IsEnabled, Mode=OneWay}"
                                                Tag="MoveFocusedWindowToPreviousDesktopHotkeyEditor" />
                                            <CheckBox
                                                x:Uid="SettingsPage_MovePreviousHotkeyAltCheckBox"
                                                Click="OnModifierSelectionCheckBoxClicked"
                                                Content="Alt"
                                                IsChecked="{x:Bind ViewModel.MoveFocusedWindowToPreviousDesktopHotkeyEditor.RequiredKeyboardModifierSelection.IsAlternateEnabled, Mode=TwoWay}"
                                                IsEnabled="{x:Bind ViewModel.MoveFocusedWindowToPreviousDesktopHotkeyEditor.IsEnabled, Mode=OneWay}"
                                                Tag="MoveFocusedWindowToPreviousDesktopHotkeyEditor" />
                                            <CheckBox
                                                x:Uid="SettingsPage_MovePreviousHotkeyWindowsCheckBox"
                                                Click="OnModifierSelectionCheckBoxClicked"
                                                Content="Windows"
                                                IsChecked="{x:Bind ViewModel.MoveFocusedWindowToPreviousDesktopHotkeyEditor.RequiredKeyboardModifierSelection.IsWindowsEnabled, Mode=TwoWay}"
                                                IsEnabled="{x:Bind ViewModel.MoveFocusedWindowToPreviousDesktopHotkeyEditor.IsEnabled, Mode=OneWay}"
                                                Tag="MoveFocusedWindowToPreviousDesktopHotkeyEditor" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>

                            <Grid Grid.Row="5" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel
                                    Grid.Row="0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Ellipse
                                        Width="10"
                                        Height="10"
                                        VerticalAlignment="Center"
                                        Fill="{x:Bind GetKeyboardShortcutValidationForegroundBrush(ViewModel.NavigatorToggleHotkeyValidationState), Mode=OneWay}" />
                                    <TextBlock Foreground="{x:Bind GetKeyboardShortcutValidationForegroundBrush(ViewModel.NavigatorToggleHotkeyValidationState), Mode=OneWay}" Text="{x:Bind GetKeyboardShortcutValidationText(ViewModel.NavigatorToggleHotkeyValidationState), Mode=OneWay}" />
                                </StackPanel>
                                <Grid Grid.Row="1" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleSwitch
                                        x:Name="NavigatorToggleHotkeyToggleSwitch"
                                        x:Uid="SettingsPage_NavigatorToggleHotkeyToggleSwitch"
                                        Grid.Column="0"
                                        Margin="0,-8"
                                        VerticalAlignment="Center"
                                        Header="Navigator 오버레이 토글"
                                        IsOn="{x:Bind ViewModel.NavigatorToggleHotkeyEditor.IsEnabled, Mode=TwoWay}"
                                        Toggled="OnSettingToggleSwitchToggled" />
                                    <ComboBox
                                        x:Uid="SettingsPage_NavigatorToggleHotkeyKeyComboBox"
                                        Grid.Column="1"
                                        VerticalAlignment="Top"
                                        Header="기본 키"
                                        IsEnabled="{x:Bind ViewModel.NavigatorToggleHotkeyEditor.IsEnabled, Mode=OneWay}"
                                        ItemTemplate="{StaticResource SelectionOptionTextTemplate}"
                                        ItemsSource="{x:Bind ViewModel.NavigatorToggleHotkeyEditor.KeyboardShortcutTriggerOptions, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.NavigatorToggleHotkeyEditor.SelectedKeyboardShortcutTriggerOption, Mode=TwoWay}"
                                        SelectionChanged="OnSettingSelectionChanged" />
                                    <StackPanel
                                        Grid.Column="2"
                                        VerticalAlignment="Top"
                                        Spacing="10">
                                        <TextBlock
                                            x:Uid="SettingsPage_NavigatorToggleHotkeyModifierTextBlock"
                                            Foreground="{x:Bind GetHotkeyLabelForegroundBrush(ViewModel.NavigatorToggleHotkeyEditor.IsEnabled), Mode=OneWay}"
                                            Text="보조 키" />
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <CheckBox
                                                x:Uid="SettingsPage_NavigatorToggleHotkeyControlCheckBox"
                                                Click="OnModifierSelectionCheckBoxClicked"
                                                Content="Ctrl"
                                                IsChecked="{x:Bind ViewModel.NavigatorToggleHotkeyEditor.RequiredKeyboardModifierSelection.IsControlEnabled, Mode=TwoWay}"
                                                IsEnabled="{x:Bind ViewModel.NavigatorToggleHotkeyEditor.IsEnabled, Mode=OneWay}"
                                                Tag="NavigatorToggleHotkeyEditor" />
                                            <CheckBox
                                                x:Uid="SettingsPage_NavigatorToggleHotkeyShiftCheckBox"
                                                Click="OnModifierSelectionCheckBoxClicked"
                                                Content="Shift"
                                                IsChecked="{x:Bind ViewModel.NavigatorToggleHotkeyEditor.RequiredKeyboardModifierSelection.IsShiftEnabled, Mode=TwoWay}"
                                                IsEnabled="{x:Bind ViewModel.NavigatorToggleHotkeyEditor.IsEnabled, Mode=OneWay}"
                                                Tag="NavigatorToggleHotkeyEditor" />
                                            <CheckBox
                                                x:Uid="SettingsPage_NavigatorToggleHotkeyAltCheckBox"
                                                Click="OnModifierSelectionCheckBoxClicked"
                                                Content="Alt"
                                                IsChecked="{x:Bind ViewModel.NavigatorToggleHotkeyEditor.RequiredKeyboardModifierSelection.IsAlternateEnabled, Mode=TwoWay}"
                                                IsEnabled="{x:Bind ViewModel.NavigatorToggleHotkeyEditor.IsEnabled, Mode=OneWay}"
                                                Tag="NavigatorToggleHotkeyEditor" />
                                            <CheckBox
                                                x:Uid="SettingsPage_NavigatorToggleHotkeyWindowsCheckBox"
                                                Click="OnModifierSelectionCheckBoxClicked"
                                                Content="Windows"
                                                IsChecked="{x:Bind ViewModel.NavigatorToggleHotkeyEditor.RequiredKeyboardModifierSelection.IsWindowsEnabled, Mode=TwoWay}"
                                                IsEnabled="{x:Bind ViewModel.NavigatorToggleHotkeyEditor.IsEnabled, Mode=OneWay}"
                                                Tag="NavigatorToggleHotkeyEditor" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="6">
                                <TextBlock
                                    x:Uid="SettingsPage_NavigatorSectionTitleTextBlock"
                                    FontWeight="SemiBold"
                                    Text="Navigator" />
                                <TextBlock
                                    x:Uid="SettingsPage_NavigatorSectionDescriptionTextBlock"
                                    Text="오버레이 단축키와 마우스 트리거 영역을 구성합니다."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Grid
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                                <Button
                                    x:Name="NavigatorSectionHelpButton"
                                    Click="OnSectionHelpButtonClicked"
                                    Style="{StaticResource SectionHelpButtonStyle}"
                                    Tag="{x:Bind NavigatorSectionTeachingTip}">
                                    <FontIcon Glyph="&#xE9CE;" />
                                </Button>
                                <TeachingTip
                                    x:Name="NavigatorSectionTeachingTip"
                                    x:Uid="SettingsPage_NavigatorSectionTeachingTip"
                                    Title="Navigator 안내"
                                    Closed="OnSectionTeachingTipClosed"
                                    IsLightDismissEnabled="True"
                                    Target="{x:Bind NavigatorSectionHelpButton}">
                                    <TeachingTip.Content>
                                        <TextBlock
                                            x:Uid="SettingsPage_NavigatorSectionTeachingTipContentTextBlock"
                                            Style="{StaticResource SectionTeachingTipContentTextBlockStyle}"
                                            Text="Navigator 섹션의 각 설정 설명" />
                                    </TeachingTip.Content>
                                </TeachingTip>
                            </Grid>
                        </Grid>

                        <ToggleSwitch
                            x:Name="NavigatorTriggerAreaToggleSwitch"
                            x:Uid="SettingsPage_NavigatorTriggerAreaToggleSwitch"
                            Header="트리거 영역 사용"
                            IsOn="{x:Bind ViewModel.IsNavigatorTriggerAreaEnabled, Mode=TwoWay}"
                            Toggled="OnSettingToggleSwitchToggled" />

                        <Border
                            Padding="12"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            CornerRadius="10">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    x:Uid="SettingsPage_NavigatorTriggerAreaSummaryTitleTextBlock"
                                    FontWeight="SemiBold"
                                    Text="선택된 영역" />
                                <TextBlock Text="{x:Bind ViewModel.NavigatorTriggerAreaSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    x:Uid="SettingsPage_NavigatorTriggerAreaHintTextBlock"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="영역 선택을 누르면 현재 설정 창이 있는 모니터에서 드래그로 지정합니다."
                                    TextWrapping="WrapWholeWords" />
                                <Button
                                    x:Name="SelectNavigatorTriggerAreaButton"
                                    x:Uid="SettingsPage_SelectNavigatorTriggerAreaButton"
                                    HorizontalAlignment="Left"
                                    Click="OnSelectNavigatorTriggerAreaButtonClicked"
                                    Content="영역 선택" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="6">
                                <TextBlock
                                    x:Uid="SettingsPage_BlacklistSectionTitleTextBlock"
                                    FontWeight="SemiBold"
                                    Text="블랙리스트" />
                                <TextBlock
                                    x:Uid="SettingsPage_BlacklistSectionDescriptionTextBlock"
                                    Text="가장자리 처리에서 제외할 프로세스 이름을 관리합니다."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Grid
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                                <Button
                                    x:Name="BlacklistSectionHelpButton"
                                    Click="OnSectionHelpButtonClicked"
                                    Style="{StaticResource SectionHelpButtonStyle}"
                                    Tag="{x:Bind BlacklistSectionTeachingTip}">
                                    <FontIcon Glyph="&#xE9CE;" />
                                </Button>
                                <TeachingTip
                                    x:Name="BlacklistSectionTeachingTip"
                                    x:Uid="SettingsPage_BlacklistSectionTeachingTip"
                                    Title="블랙리스트 안내"
                                    Closed="OnSectionTeachingTipClosed"
                                    IsLightDismissEnabled="True"
                                    Target="{x:Bind BlacklistSectionHelpButton}">
                                    <TeachingTip.Content>
                                        <TextBlock
                                            x:Uid="SettingsPage_BlacklistSectionTeachingTipContentTextBlock"
                                            Style="{StaticResource SectionTeachingTipContentTextBlockStyle}"
                                            Text="블랙리스트 섹션의 각 설정 설명" />
                                    </TeachingTip.Content>
                                </TeachingTip>
                            </Grid>
                        </Grid>

                        <Button
                            x:Uid="SettingsPage_AddBlacklistedProcessNameButton"
                            HorizontalAlignment="Left"
                            Click="OnAddBlacklistedProcessNameButtonClicked"
                            Content="실행된 프로세스에서 추가" />

                        <ListView
                            x:Name="BlacklistedProcessNamesListView"
                            ItemsSource="{x:Bind ViewModel.BlacklistedProcessNames, Mode=OneWay}"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Text="{Binding}" />
                                        <Button
                                            Grid.Column="1"
                                            MinWidth="0"
                                            Padding="8"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Click="OnRemoveBlacklistedProcessNameButtonClicked"
                                            Tag="{Binding}">
                                            <Button.Content>
                                                <SymbolIcon Symbol="Delete" />
                                            </Button.Content>
                                            <ToolTipService.ToolTip>
                                                <ToolTip x:Uid="SettingsPage_RemoveBlacklistedProcessNameButtonToolTip" Content="제거" />
                                            </ToolTipService.ToolTip>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="6">
                                <TextBlock
                                    x:Uid="SettingsPage_WhitelistSectionTitleTextBlock"
                                    FontWeight="SemiBold"
                                    Text="화이트리스트" />
                                <TextBlock
                                    x:Uid="SettingsPage_WhitelistSectionDescriptionTextBlock"
                                    Text="게임으로 인식되는 프로그램이 자동 추가되어 오작동하는 경우를 방지하기 위해 항상 허용할 프로세스 이름을 관리합니다."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Grid
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                                <Button
                                    x:Name="WhitelistSectionHelpButton"
                                    Click="OnSectionHelpButtonClicked"
                                    Style="{StaticResource SectionHelpButtonStyle}"
                                    Tag="{x:Bind WhitelistSectionTeachingTip}">
                                    <FontIcon Glyph="&#xE9CE;" />
                                </Button>
                                <TeachingTip
                                    x:Name="WhitelistSectionTeachingTip"
                                    x:Uid="SettingsPage_WhitelistSectionTeachingTip"
                                    Title="화이트리스트 안내"
                                    Closed="OnSectionTeachingTipClosed"
                                    IsLightDismissEnabled="True"
                                    Target="{x:Bind WhitelistSectionHelpButton}">
                                    <TeachingTip.Content>
                                        <TextBlock
                                            x:Uid="SettingsPage_WhitelistSectionTeachingTipContentTextBlock"
                                            Style="{StaticResource SectionTeachingTipContentTextBlockStyle}"
                                            Text="화이트리스트 섹션의 각 설정 설명" />
                                    </TeachingTip.Content>
                                </TeachingTip>
                            </Grid>
                        </Grid>

                        <Button
                            x:Uid="SettingsPage_AddWhitelistedProcessNameButton"
                            HorizontalAlignment="Left"
                            Click="OnAddWhitelistedProcessNameButtonClicked"
                            Content="실행된 프로세스와 블랙리스트에서 추가" />

                        <ListView
                            x:Name="WhitelistedProcessNamesListView"
                            ItemsSource="{x:Bind ViewModel.WhitelistedProcessNames, Mode=OneWay}"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Text="{Binding}" />
                                        <Button
                                            Grid.Column="1"
                                            MinWidth="0"
                                            Padding="8"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Click="OnRemoveWhitelistedProcessNameButtonClicked"
                                            Tag="{Binding}">
                                            <Button.Content>
                                                <SymbolIcon Symbol="Delete" />
                                            </Button.Content>
                                            <ToolTipService.ToolTip>
                                                <ToolTip x:Uid="SettingsPage_RemoveWhitelistedProcessNameButtonToolTip" Content="제거" />
                                            </ToolTipService.ToolTip>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="6">
                                <TextBlock
                                    x:Uid="SettingsPage_DeveloperSectionTitleTextBlock"
                                    FontWeight="SemiBold"
                                    Text="개발자" />
                                <TextBlock
                                    x:Uid="SettingsPage_DeveloperSectionDescriptionTextBlock"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="진단과 문제 재현에 필요한 도구를 제공합니다."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Grid
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                                <Button
                                    x:Name="DeveloperSectionHelpButton"
                                    Click="OnSectionHelpButtonClicked"
                                    Style="{StaticResource SectionHelpButtonStyle}"
                                    Tag="{x:Bind DeveloperSectionTeachingTip}">
                                    <FontIcon Glyph="&#xE9CE;" />
                                </Button>
                                <TeachingTip
                                    x:Name="DeveloperSectionTeachingTip"
                                    x:Uid="SettingsPage_DeveloperSectionTeachingTip"
                                    Title="개발자 안내"
                                    Closed="OnSectionTeachingTipClosed"
                                    IsLightDismissEnabled="True"
                                    Target="{x:Bind DeveloperSectionHelpButton}">
                                    <TeachingTip.Content>
                                        <TextBlock
                                            x:Uid="SettingsPage_DeveloperSectionTeachingTipContentTextBlock"
                                            Style="{StaticResource SectionTeachingTipContentTextBlockStyle}"
                                            Text="개발자 섹션의 각 설정 설명" />
                                    </TeachingTip.Content>
                                </TeachingTip>
                            </Grid>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="6">
                                <TextBlock
                                    x:Uid="SettingsPage_IntegratedLogExportTitleTextBlock"
                                    FontWeight="SemiBold"
                                    Text="통합 로그 다운로드" />
                                <TextBlock
                                    x:Uid="SettingsPage_IntegratedLogExportDescriptionTextBlock"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="앱 실행 중 기록된 로그를 파일로 저장합니다. (최대 1,000건)"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Button
                                x:Name="ExportIntegratedLogButton"
                                x:Uid="SettingsPage_ExportIntegratedLogButton"
                                Grid.Column="1"
                                MinWidth="120"
                                VerticalAlignment="Bottom"
                                Click="OnExportIntegratedLogButtonClicked"
                                Content="저장" />
                        </Grid>

                        <InfoBar
                            x:Name="DeveloperLogInfoBar"
                            IsClosable="False"
                            IsOpen="False"
                            Severity="Informational" />
                    </StackPanel>
                </Border>

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="6">
                                <TextBlock
                                    x:Uid="SettingsPage_ImportExportSectionTitleTextBlock"
                                    FontWeight="SemiBold"
                                    Text="설정 불러오기 및 내보내기" />
                                <TextBlock
                                    x:Uid="SettingsPage_ImportExportSectionDescriptionTextBlock"
                                    Text=".dbs 파일로 현재 설정을 저장하거나, 저장된 설정 파일을 현재 앱 상태에 반영할 수 있습니다."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Grid
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                                <Button
                                    x:Name="ImportExportSectionHelpButton"
                                    Click="OnSectionHelpButtonClicked"
                                    Style="{StaticResource SectionHelpButtonStyle}"
                                    Tag="{x:Bind ImportExportSectionTeachingTip}">
                                    <FontIcon Glyph="&#xE9CE;" />
                                </Button>
                                <TeachingTip
                                    x:Name="ImportExportSectionTeachingTip"
                                    x:Uid="SettingsPage_ImportExportSectionTeachingTip"
                                    Title="설정 불러오기 및 내보내기 안내"
                                    Closed="OnSectionTeachingTipClosed"
                                    IsLightDismissEnabled="True"
                                    PreferredPlacement="TopLeft"
                                    Target="{x:Bind ImportExportSectionHelpButton}">
                                    <TeachingTip.Content>
                                        <TextBlock
                                            x:Uid="SettingsPage_ImportExportSectionTeachingTipContentTextBlock"
                                            Style="{StaticResource SectionTeachingTipContentTextBlockStyle}"
                                            Text="설정 불러오기 및 내보내기 섹션의 각 설정 설명" />
                                    </TeachingTip.Content>
                                </TeachingTip>
                            </Grid>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button
                                x:Name="ExportSettingsButton"
                                x:Uid="SettingsPage_ExportSettingsButton"
                                Click="OnExportSettingsButtonClicked"
                                Content="설정 내보내기" />
                            <Button
                                x:Name="ImportSettingsButton"
                                x:Uid="SettingsPage_ImportSettingsButton"
                                Click="OnImportSettingsButtonClicked"
                                Content="설정 불러오기" />
                            <Button
                                x:Name="ResetSettingsButton"
                                x:Uid="SettingsPage_ResetSettingsButton"
                                Click="OnResetSettingsButtonClicked"
                                Content="설정 초기화" />
                        </StackPanel>

                        <InfoBar
                            x:Name="SettingsImportExportInfoBar"
                            IsClosable="False"
                            IsOpen="False"
                            Severity="Informational" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
