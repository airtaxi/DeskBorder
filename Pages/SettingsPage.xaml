<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DeskBorder.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:DeskBorder.ViewModels"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="SelectionOptionTextTemplate" x:DataType="vm:SelectionOptionBase">
            <TextBlock Text="{x:Bind DisplayText}" />
        </DataTemplate>
        <Style x:Key="SectionHelpButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style x:Key="SectionTeachingTipContentTextBlockStyle" TargetType="TextBlock">
            <Setter Property="MaxWidth" Value="420" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>
    </Page.Resources>
    <Grid Padding="24" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Uid="SettingsPage_TitleTextBlock"
            Grid.Row="0"
            Style="{ThemeResource TitleTextBlockStyle}"
            Text="설정" />

        <InfoBar
            x:Name="SettingsStatusInfoBar"
            Grid.Row="1"
            IsClosable="False"
            IsOpen="False"
            Severity="Error" />

        <ScrollViewer Grid.Row="2">
            <StackPanel Spacing="20">
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="6">
                                <TextBlock
                                    x:Uid="SettingsPage_GeneralSectionTitleTextBlock"
                                    FontWeight="SemiBold"
                                    Text="일반" />
                                <TextBlock
                                    x:Uid="SettingsPage_GeneralSectionDescriptionTextBlock"
                                    Text="앱 전반 동작, 시작 옵션, 업데이트 확인 정책을 설정합니다."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Grid
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                                <Button
                                    x:Name="GeneralSectionHelpButton"
                                    Click="OnSectionHelpButtonClicked"
                                    Style="{StaticResource SectionHelpButtonStyle}"
                                    Tag="{x:Bind GeneralSectionTeachingTip}">
                                    <FontIcon Glyph="&#xE9CE;" />
                                </Button>
                                <TeachingTip
                                    x:Name="GeneralSectionTeachingTip"
                                    x:Uid="SettingsPage_GeneralSectionTeachingTip"
                                    Title="일반 설정 안내"
                                    Closed="OnSectionTeachingTipClosed"
                                    IsLightDismissEnabled="True"
                                    Target="{x:Bind GeneralSectionHelpButton}">
                                    <TeachingTip.Content>
                                        <TextBlock
                                            x:Uid="SettingsPage_GeneralSectionTeachingTipContentTextBlock"
                                            Style="{StaticResource SectionTeachingTipContentTextBlockStyle}"
                                            Text="일반 섹션의 각 설정 설명" />
                                    </TeachingTip.Content>
                                </TeachingTip>
                            </Grid>
                        </Grid>

                        <ToggleSwitch
                            x:Name="DeskBorderEnabledToggleSwitch"
                            x:Uid="SettingsPage_DeskBorderEnabledToggleSwitch"
                            Header="DeskBorder 사용"
                            IsOn="{x:Bind ViewModel.IsDeskBorderEnabled, Mode=TwoWay}"
                            Toggled="OnSettingToggleSwitchToggled" />

                        <ToggleSwitch
                            x:Name="LaunchOnStartupToggleSwitch"
                            x:Uid="SettingsPage_LaunchOnStartupToggleSwitch"
                            Header="시스템 시작 시 자동 실행"
                            IsOn="{x:Bind ViewModel.IsLaunchOnStartupEnabled, Mode=TwoWay}"
                            Toggled="OnSettingToggleSwitchToggled" />

                        <Border
                            Padding="14"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            CornerRadius="10">
                            <StackPanel Spacing="14">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Width="36"
                                        Height="36"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="10">
                                        <FontIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                            Glyph="&#xE72E;" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock
                                            x:Uid="SettingsPage_AdministratorModeTitleTextBlock"
                                            FontWeight="SemiBold"
                                            Text="관리자 권한으로 실행" />
                                        <TextBlock
                                            x:Uid="SettingsPage_AdministratorModeDescriptionTextBlock"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="필요한 경우 DeskBorder가 관리자 권한으로 실행되도록 설정합니다."
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Spacing="6">
                                    <ToggleSwitch
                                        x:Name="AlwaysRunAsAdministratorToggleSwitch"
                                        x:Uid="SettingsPage_AlwaysRunAsAdministratorToggleSwitch"
                                        Header="항상 Administrator 로 실행"
                                        IsOn="{x:Bind ViewModel.IsAlwaysRunAsAdministratorEnabled, Mode=TwoWay}"
                                        Toggled="OnSettingToggleSwitchToggled" />
                                    <TextBlock
                                        x:Uid="SettingsPage_AlwaysRunAsAdministratorDescriptionTextBlock"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="관리자 권한으로 실행하면 일부 환경에서 데스크톱 전환이나 마우스 이동이 동작하지 않는 문제를 해결하는 데 도움이 될 수 있습니다. 설정 후 다음 실행부터 적용됩니다."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <ToggleSwitch
                            x:Name="StoreUpdateCheckToggleSwitch"
                            x:Uid="SettingsPage_StoreUpdateCheckToggleSwitch"
                            Header="스토어 업데이트 확인"
                            IsOn="{x:Bind ViewModel.IsStoreUpdateCheckEnabled, Mode=TwoWay}"
                            Toggled="OnSettingToggleSwitchToggled" />

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="8">
                                <TextBlock
                                    x:Uid="SettingsPage_StoreUpdateStatusTitleTextBlock"
                                    FontWeight="SemiBold"
                                    Text="업데이트 확인" />
                                <TextBlock
                                    x:Name="StoreUpdateStatusTextBlock"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="WrapWholeWords" />
                                <InfoBar
                                    x:Name="StoreUpdateVersionInfoBar"
                                    IsClosable="False"
                                    IsOpen="True"
                                    Severity="Informational" />
                            </StackPanel>
                            <Button
                                x:Name="CheckStoreUpdateButton"
                                x:Uid="SettingsPage_CheckStoreUpdateButton"
                                Grid.Column="1"
                                MinWidth="120"
                                Margin="0,0,0,10"
                                VerticalAlignment="Bottom"
                                Click="OnCheckStoreUpdateButtonClicked"
                                Content="확인하기" />
                        </Grid>

                        <ComboBox
                            x:Name="MultiDisplayBehaviorComboBox"
                            x:Uid="SettingsPage_MultiDisplayBehaviorComboBox"
                            Header="다중 디스플레이 동작"
                            IsEnabled="{x:Bind GetMultiDisplayBehaviorSelectionEnabled(ViewModel.IsVerticalDesktopSwitchingEnabled), Mode=OneWay}"
                            ItemTemplate="{StaticResource SelectionOptionTextTemplate}"
                            ItemsSource="{x:Bind ViewModel.MultiDisplayBehaviorOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedMultiDisplayBehaviorOption, Mode=TwoWay}"
                            SelectionChanged="OnSettingSelectionChanged" />

                        <ComboBox
                            x:Name="ApplicationThemePreferenceComboBox"
                            x:Uid="SettingsPage_ApplicationThemePreferenceComboBox"
                            Header="앱 테마"
                            ItemTemplate="{StaticResource SelectionOptionTextTemplate}"
                            ItemsSource="{x:Bind ViewModel.ApplicationThemePreferenceOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedApplicationThemePreferenceOption, Mode=TwoWay}"
                            SelectionChanged="OnSettingSelectionChanged" />

                        <ComboBox
                            x:Name="AppLanguagePreferenceComboBox"
                            x:Uid="SettingsPage_AppLanguagePreferenceComboBox"
                            Header="앱 언어"
                            ItemTemplate="{StaticResource SelectionOptionTextTemplate}"
                            ItemsSource="{x:Bind ViewModel.AppLanguagePreferenceOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedAppLanguagePreferenceOption, Mode=TwoWay}"
                            SelectionChanged="OnSettingSelectionChanged" />
                    </StackPanel>
                </Border>

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="6">
                                <TextBlock
                                    x:Uid="SettingsPage_EdgeSectionTitleTextBlock"
                                    FontWeight="SemiBold"
                                    Text="가장자리 및 자동 정리" />
                                <TextBlock
                                    x:Uid="SettingsPage_EdgeSectionDescriptionTextBlock"
                                    Text="다중 디스플레이 환경, 자동 삭제 정책, 가장자리 무시 영역을 설정합니다."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Grid
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                                <Button
                                    x:Name="EdgeSectionHelpButton"
                                    Click="OnSectionHelpButtonClicked"
                                    Style="{StaticResource SectionHelpButtonStyle}"
                                    Tag="{x:Bind EdgeSectionTeachingTip}">
                                    <FontIcon Glyph="&#xE9CE;" />
                                </Button>
                                <TeachingTip
                                    x:Name="EdgeSectionTeachingTip"
                                    x:Uid="SettingsPage_EdgeSectionTeachingTip"
                                    Title="가장자리 및 자동 정리 안내"
                                    Closed="OnSectionTeachingTipClosed"
                                    IsLightDismissEnabled="True"
                                    Target="{x:Bind EdgeSectionHelpButton}">
                                    <TeachingTip.Content>
                                        <TextBlock
                                            x:Uid="SettingsPage_EdgeSectionTeachingTipContentTextBlock"
                                            Style="{StaticResource SectionTeachingTipContentTextBlockStyle}"
                                            Text="가장자리 및 자동 정리 섹션의 각 설정 설명" />
                                    </TeachingTip.Content>
                                </TeachingTip>
                            </Grid>
                        </Grid>

                        <ToggleSwitch
                            x:Name="CreateDesktopEnabledToggleSwitch"
                            x:Uid="SettingsPage_CreateDesktopEnabledToggleSwitch"
                            Header="데스크톱 생성"
                            IsOn="{x:Bind ViewModel.IsDesktopCreationEnabled, Mode=TwoWay}"
                            Toggled="OnSettingToggleSwitchToggled" />

                        <Border
                            Padding="12"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            CornerRadius="10"
                            Visibility="{x:Bind GetDesktopCreationOptionControlsVisibility(ViewModel.IsDesktopCreationEnabled), Mode=OneWay}">
                            <StackPanel Spacing="12">
                                <ToggleSwitch
                                    x:Name="DesktopCreationSkippedWhenCurrentDesktopIsEmptyToggleSwitch"
                                    x:Uid="SettingsPage_DesktopCreationSkippedWhenCurrentDesktopIsEmptyToggleSwitch"
                                    Header="현재 데스크톱이 비어 있으면 생성 안 함"
                                    IsOn="{x:Bind ViewModel.IsDesktopCreationSkippedWhenCurrentDesktopIsEmpty, Mode=TwoWay}"
                                    Toggled="OnSettingToggleSwitchToggled" />

                                <ToggleSwitch
                                    x:Name="DesktopCreationCompletionToastToggleSwitch"
                                    x:Uid="SettingsPage_DesktopCreationCompletionToastToggleSwitch"
                                    Header="자동 생성 완료 알림 표시"
                                    IsOn="{x:Bind ViewModel.IsDesktopCreationCompletionToastEnabled, Mode=TwoWay}"
                                    Toggled="OnSettingToggleSwitchToggled" />
                            </StackPanel>
                        </Border>

                        <ToggleSwitch
                            x:Name="DesktopSwitchingAndCreationDisabledWhenFullscreenToggleSwitch"
                            x:Uid="SettingsPage_DesktopSwitchingAndCreationDisabledWhenFullscreenToggleSwitch"
                            Header="전체화면일 때 전환 및 생성 비활성화"
                            IsOn="{x:Bind ViewModel.IsDesktopSwitchingAndCreationDisabledWhenForegroundWindowIsFullscreen, Mode=TwoWay}"
                            Toggled="OnSettingToggleSwitchToggled" />

                        <Border
                            Padding="12"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            CornerRadius="10"
                            Visibility="{x:Bind GetFullscreenOptionControlsVisibility(ViewModel.IsDesktopSwitchingAndCreationDisabledWhenForegroundWindowIsFullscreen), Mode=OneWay}">
                            <StackPanel Spacing="12">
                                <ToggleSwitch
                                    x:Name="WindowedFullscreenIncludedToggleSwitch"
                                    x:Uid="SettingsPage_WindowedFullscreenIncludedToggleSwitch"
                                    Header="창모드 전체화면 포함"
                                    IsOn="{x:Bind ViewModel.IsWindowedFullscreenIncludedWhenDisablingDesktopSwitchingAndCreation, Mode=TwoWay}"
                                    Toggled="OnSettingToggleSwitchToggled" />
                            </StackPanel>
                        </Border>

                        <ToggleSwitch
                            x:Name="AutoDeleteToggleSwitch"
                            x:Uid="SettingsPage_AutoDeleteToggleSwitch"
                            Header="빈 데스크톱 자동 삭제"
                            IsOn="{x:Bind ViewModel.IsAutoDeleteEnabled, Mode=TwoWay}"
                            Toggled="OnSettingToggleSwitchToggled" />

                        <Border
                            Padding="12"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            CornerRadius="10"
                            Visibility="{x:Bind GetAutoDeleteOptionControlsVisibility(ViewModel.IsAutoDeleteEnabled), Mode=OneWay}">
                            <StackPanel Spacing="12">
                                <ToggleSwitch
                                    x:Name="AutoDeleteWarningToggleSwitch"
                                    x:Uid="SettingsPage_AutoDeleteWarningToggleSwitch"
                                    Header="삭제 경고 표시"
                                    IsOn="{x:Bind ViewModel.IsAutoDeleteWarningEnabled, Mode=TwoWay}"
                                    Toggled="OnSettingToggleSwitchToggled" />

                                <ToggleSwitch
                                    x:Name="AutoDeleteCompletionToastToggleSwitch"
                                    x:Uid="SettingsPage_AutoDeleteCompletionToastToggleSwitch"
                                    Header="자동 삭제 완료 알림 표시"
                                    IsOn="{x:Bind ViewModel.IsAutoDeleteCompletionToastEnabled, Mode=TwoWay}"
                                    Toggled="OnSettingToggleSwitchToggled"
                                    Visibility="{x:Bind GetAutoDeleteCompletionToastVisibility(ViewModel.IsAutoDeleteWarningEnabled), Mode=OneWay}" />

                                <Border
                                    Padding="12"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    CornerRadius="10"
                                    Visibility="{x:Bind GetAutoDeleteWarningTimeoutVisibility(ViewModel.IsAutoDeleteWarningEnabled), Mode=OneWay}">
                                    <StackPanel Spacing="8">
                                        <TextBlock
                                            x:Uid="SettingsPage_AutoDeleteWarningTimeoutDescriptionTextBlock"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="삭제 경고가 켜져 있을 때 실행 취소를 기다리는 시간을 조절합니다."
                                            TextWrapping="WrapWholeWords" />
                                        <NumberBox
                                            x:Name="AutoDeleteWarningTimeoutSecondsNumberBox"
                                            x:Uid="SettingsPage_AutoDeleteWarningTimeoutSecondsNumberBox"
                                            Header="삭제 경고 타임아웃 (초)"
                                            Maximum="10"
                                            Minimum="0.5"
                                            SmallChange="0.5"
                                            SpinButtonPlacementMode="Inline"
                                            ValueChanged="OnSettingNumberBoxValueChanged"
                                            Value="{x:Bind ViewModel.AutoDeleteWarningTimeoutSeconds, Mode=TwoWay}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <ToggleSwitch
                            x:Name="DesktopEdgeAdditionalTriggerDistanceToggleSwitch"
                            x:Uid="SettingsPage_DesktopEdgeAdditionalTriggerDistanceToggleSwitch"
                            Header="가장자리 추가 이동 거리 사용"
                            IsOn="{x:Bind ViewModel.IsDesktopEdgeAdditionalTriggerDistanceEnabled, Mode=TwoWay}"
                            Toggled="OnSettingToggleSwitchToggled" />

                        <Border
                            Padding="12"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            CornerRadius="10"
                            Visibility="{x:Bind GetDesktopEdgeAdditionalTriggerDistanceVisibility(ViewModel.IsDesktopEdgeAdditionalTriggerDistanceEnabled), Mode=OneWay}">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    x:Uid="SettingsPage_DesktopEdgeAdditionalTriggerDistanceDescriptionTextBlock"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="가장자리에 닿은 뒤에도 바깥쪽으로 마우스를 더 민 거리가 현재 모니터 너비의 지정 비율 이상일 때만 전환 또는 생성합니다."
                                    TextWrapping="WrapWholeWords" />
                                <NumberBox
                                    x:Name="DesktopEdgeAdditionalTriggerDistancePercentageNumberBox"
                                    x:Uid="SettingsPage_DesktopEdgeAdditionalTriggerDistancePercentageNumberBox"
                                    Header="추가 이동 거리 (%)"
                                    Maximum="50"
                                    Minimum="0.1"
                                    SmallChange="0.5"
                                    SpinButtonPlacementMode="Inline"
                                    ValueChanged="OnSettingNumberBoxValueChanged"
                                    Value="{x:Bind ViewModel.DesktopEdgeAdditionalTriggerDistancePercentage, Mode=TwoWay}" />
                                </StackPanel>
                        </Border>

                        <ToggleSwitch
                            x:Name="VerticalDesktopSwitchingToggleSwitch"
                            x:Uid="SettingsPage_VerticalDesktopSwitchingToggleSwitch"
                            Header="위/아래 경계로도 데스크톱 전환"
                            IsOn="{x:Bind ViewModel.IsVerticalDesktopSwitchingEnabled, Mode=TwoWay}"
                            Toggled="OnSettingToggleSwitchToggled" />

                        <Border
                            Padding="12"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            CornerRadius="10"
                            Visibility="{x:Bind GetVerticalDesktopSwitchingOptionsVisibility(ViewModel.AreVerticalDesktopSwitchingOptionControlsVisible), Mode=OneWay}">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    x:Uid="SettingsPage_VerticalDesktopSwitchingDescriptionTextBlock"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="위/아래 경계를 사용해도 기존 좌우 전환은 그대로 유지됩니다. 다중 디스플레이 동작 콤보는 적용되지 않습니다."
                                    TextWrapping="WrapWholeWords" />
                                <ToggleSwitch
                                    x:Name="VerticalDesktopSwitchDirectionReversedToggleSwitch"
                                    x:Uid="SettingsPage_VerticalDesktopSwitchDirectionReversedToggleSwitch"
                                    Header="위=다음, 아래=이전으로 방향 반전"
                                    IsOn="{x:Bind ViewModel.IsVerticalDesktopSwitchDirectionReversed, Mode=TwoWay}"
                                    Toggled="OnSettingToggleSwitchToggled" />
                                <ToggleSwitch
                                    x:Name="VerticalDesktopSwitchingOnlyInMultiDisplayEnvironmentToggleSwitch"
                                    x:Uid="SettingsPage_VerticalDesktopSwitchingOnlyInMultiDisplayEnvironmentToggleSwitch"
                                    Header="다중 디스플레이에서만 위/아래 경계 사용"
                                    IsOn="{x:Bind ViewModel.IsVerticalDesktopSwitchingOnlyInMultiDisplayEnvironment, Mode=TwoWay}"
                                    Toggled="OnSettingToggleSwitchToggled" />
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <NumberBox
                                x:Name="TopDesktopEdgeIgnorePercentageNumberBox"
                                x:Uid="SettingsPage_TopDesktopEdgeIgnorePercentageNumberBox"
                                Header="상단 무시 영역 (%)"
                                Maximum="49"
                                Minimum="0"
                                SmallChange="1"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="OnSettingNumberBoxValueChanged"
                                Value="{x:Bind ViewModel.TopDesktopEdgeIgnorePercentage, Mode=TwoWay}" />

                            <NumberBox
                                x:Name="BottomDesktopEdgeIgnorePercentageNumberBox"
                                x:Uid="SettingsPage_BottomDesktopEdgeIgnorePercentageNumberBox"
                                Grid.Column="1"
                                Header="하단 무시 영역 (%)"
                                Maximum="49"
                                Minimum="0"
                                SmallChange="1"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="OnSettingNumberBoxValueChanged"
                                Value="{x:Bind ViewModel.BottomDesktopEdgeIgnorePercentage, Mode=TwoWay}" />
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox
                                x:Uid="SettingsPage_HotkeyTriggeredDesktopSwitchMouseLocationComboBox"
                                HorizontalAlignment="Stretch"
                                Header="단축키 데스크톱 전환 후 마우스 위치"
                                ItemTemplate="{StaticResource SelectionOptionTextTemplate}"
                                ItemsSource="{x:Bind ViewModel.DesktopSwitchMouseLocationOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedHotkeyTriggeredMouseLocationOption, Mode=TwoWay}"
                                SelectionChanged="OnSettingSelectionChanged" />
                            <ComboBox
                                x:Uid="SettingsPage_DesktopEdgeTriggeredDesktopSwitchMouseLocationComboBox"
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                Header="가장자리 데스크톱 전환 후 마우스 위치"
                                ItemTemplate="{StaticResource SelectionOptionTextTemplate}"
                                ItemsSource="{x:Bind ViewModel.DesktopSwitchMouseLocationOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedDesktopEdgeTriggeredMouseLocationOption, Mode=TwoWay}"
                                SelectionChanged="OnSettingSelectionChanged" />
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Padding="12"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="10">
                                <StackPanel Spacing="10">
                                    <TextBlock
                                        x:Uid="SettingsPage_SwitchDesktopModifierTitleTextBlock"
                                        FontWeight="SemiBold"
                                        Text="데스크톱 전환 보조키" />
                                    <CheckBox
                                        x:Uid="SettingsPage_SwitchDesktopControlCheckBox"
                                        Click="OnModifierSelectionCheckBoxClicked"
                                        Content="Ctrl"
                                        IsChecked="{x:Bind ViewModel.SwitchDesktopModifierSelection.IsControlEnabled, Mode=TwoWay}"
                                        Tag="SwitchDesktopModifierSelection" />
                                    <CheckBox
                                        x:Uid="SettingsPage_SwitchDesktopShiftCheckBox"
                                        Click="OnModifierSelectionCheckBoxClicked"
                                        Content="Shift"
                                        IsChecked="{x:Bind ViewModel.SwitchDesktopModifierSelection.IsShiftEnabled, Mode=TwoWay}"
                                        Tag="SwitchDesktopModifierSelection" />
                                    <CheckBox
                                        x:Uid="SettingsPage_SwitchDesktopAltCheckBox"
                                        Click="OnModifierSelectionCheckBoxClicked"
                                        Content="Alt"
                                        IsChecked="{x:Bind ViewModel.SwitchDesktopModifierSelection.IsAlternateEnabled, Mode=TwoWay}"
                                        Tag="SwitchDesktopModifierSelection" />
                                    <CheckBox
                                        x:Uid="SettingsPage_SwitchDesktopWindowsCheckBox"
                                        Click="OnModifierSelectionCheckBoxClicked"
                                        Content="Windows"
                                        IsChecked="{x:Bind ViewModel.SwitchDesktopModifierSelection.IsWindowsEnabled, Mode=TwoWay}"
                                        Tag="SwitchDesktopModifierSelection" />
                                </StackPanel>
                            </Border>

                            <Border
                                Grid.Column="1"
                                Padding="12"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="10">
                                <StackPanel Spacing="10">
                                    <TextBlock
                                        x:Uid="SettingsPage_CreateDesktopModifierTitleTextBlock"
                                        FontWeight="SemiBold"
                                        Text="데스크톱 생성 보조키" />
                                    <Frame IsEnabled="{x:Bind ViewModel.IsDesktopCreationEnabled, Mode=OneWay}">
                                        <StackPanel Spacing="10">
                                            <CheckBox
                                                x:Uid="SettingsPage_CreateDesktopControlCheckBox"
                                                Click="OnModifierSelectionCheckBoxClicked"
                                                Content="Ctrl"
                                                IsChecked="{x:Bind ViewModel.CreateDesktopModifierSelection.IsControlEnabled, Mode=TwoWay}"
                                                Tag="CreateDesktopModifierSelection" />
                                            <CheckBox
                                                x:Uid="SettingsPage_CreateDesktopShiftCheckBox"
                                                Click="OnModifierSelectionCheckBoxClicked"
