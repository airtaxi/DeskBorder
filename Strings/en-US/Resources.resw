  </data>
  <data name="SettingsPage_ImportExportSectionTitleTextBlock.Text" xml:space="preserve">
    <value>Import and export settings</value>
  </data>
  <data name="SettingsPage_ImportExportSectionTeachingTip.Title" xml:space="preserve">
    <value>Import and export guide</value>
  </data>
  <data name="SettingsPage_ImportExportSectionTeachingTipContentTextBlock.Text" xml:space="preserve">
    <value>• Export settings: saves the current app configuration to a .dbs file for backup or transfer to another PC.
• Import settings: loads a saved .dbs file and applies it to the current configuration in one step.
• The info bar below briefly shows import and export results or errors.</value>
  </data>
