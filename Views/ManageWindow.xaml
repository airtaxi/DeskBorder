<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="DeskBorder.Views.ManageWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:winuiex="using:WinUIEx"
    Title="DeskBorder"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <tb:TaskbarIcon
            x:Name="ApplicationTaskbarIcon"
            ContextMenuMode="SecondWindow"
            MenuActivation="RightClick"
            NoLeftClickDelay="True">
            <tb:TaskbarIcon.IconSource>
                <tb:GeneratedIconSource BackgroundSource="ms-appx:///Assets/Icon.png" />
            </tb:TaskbarIcon.IconSource>
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout AreOpenCloseAnimationsEnabled="True">
                    <MenuFlyoutItem
                        x:Name="RuntimeStatusMenuFlyoutItem"
                        IsEnabled="False"
                        Text="DeskBorder 서비스 준비 중" />
                    <MenuFlyoutItem
                        x:Name="OpenManageWindowMenuFlyoutItem"
                        Click="OnOpenManageWindowMenuFlyoutItemClicked"
                        Text="관리 창 열기" />
                    <MenuFlyoutItem
                        x:Name="ShowNavigatorMenuFlyoutItem"
                        Click="OnShowNavigatorMenuFlyoutItemClicked"
                        Text="Navigator 오버레이 표시" />
                    <ToggleMenuFlyoutItem
                        x:Name="LaunchOnStartupToggleMenuFlyoutItem"
                        Click="OnLaunchOnStartupToggleMenuFlyoutItemClicked"
                        Text="시스템 시작 시 자동 실행" />
                    <ToggleMenuFlyoutItem
                        x:Name="StoreUpdateCheckToggleMenuFlyoutItem"
                        Click="OnStoreUpdateCheckToggleMenuFlyoutItemClicked"
                        Text="스토어 업데이트 확인" />
                    <ToggleMenuFlyoutItem
                        x:Name="RuntimeToggleMenuFlyoutItem"
                        Click="OnRuntimeToggleMenuFlyoutItemClicked"
                        Text="DeskBorder 사용" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem
                        x:Name="ExitApplicationMenuFlyoutItem"
                        Click="OnExitApplicationMenuFlyoutItemClicked"
                        Text="프로그램 종료" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>

        <TitleBar
            x:Name="ApplicationTitleBar"
            Title="DeskBorder"
            Grid.Row="0"
            BackRequested="OnApplicationTitleBarBackRequested"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="False">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/Icon.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <Frame x:Name="AppFrame" Grid.Row="1" />
    </Grid>
</winuiex:WindowEx>
