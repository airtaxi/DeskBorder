<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="DeskBorder.Views.NavigatorTriggerAreaSelectionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winuiex="using:WinUIEx"
    Title="Navigator Trigger Area Selection"
    IsAlwaysOnTop="True"
    IsMaximizable="False"
    IsMinimizable="False"
    IsResizable="False"
    IsTitleBarVisible="False"
    IsVisibleInTray="False"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootGrid"
        Background="#66000000"
        KeyboardAcceleratorPlacementMode="Hidden"
        PointerCanceled="OnRootGridPointerCanceled"
        PointerMoved="OnRootGridPointerMoved"
        PointerPressed="OnRootGridPointerPressed"
        PointerReleased="OnRootGridPointerReleased">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnEscapeKeyboardAcceleratorInvoked" />
        </Grid.KeyboardAccelerators>

        <Canvas x:Name="SelectionCanvas">
            <Border
                x:Name="SelectionBorder"
                Background="#33007ACC"
                BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                BorderThickness="2"
                Visibility="Collapsed" />
        </Canvas>

        <Border
            Margin="24"
            Padding="16"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="16">
            <StackPanel MaxWidth="520" Spacing="6">
                <TextBlock
                    x:Name="SelectionTitleTextBlock"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="Select the Navigator trigger area" />
                <TextBlock
                    x:Name="SelectionDescriptionTextBlock"
                    Text="Drag to choose an area. Press Escape to cancel."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>
    </Grid>
</winuiex:WindowEx>
