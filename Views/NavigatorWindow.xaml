<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="DeskBorder.Views.NavigatorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:DeskBorder.ViewModels"
    xmlns:winuiex="using:WinUIEx"
    Title="DeskBorder Navigator"
    IsAlwaysOnTop="True"
    IsMaximizable="False"
    IsMinimizable="False"
    IsResizable="False"
    IsTitleBarVisible="False"
    IsVisibleInTray="False"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="Transparent" IsHitTestVisible="False">
        <Grid Padding="12" VerticalAlignment="Stretch">
            <Border
                Padding="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <ScrollViewer
                    HorizontalScrollBarVisibility="Hidden"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled"
                    ZoomMode="Disabled">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.DesktopItems, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:NavigatorDesktopItemViewModel">
                                <StackPanel Width="164" Spacing="8">
                                    <Grid Opacity="{x:Bind DesktopCardOpacity, Mode=OneWay}">
                                        <Border
                                            Height="92"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12" />
                                        <Border
                                            Height="92"
                                            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                            BorderThickness="2"
                                            CornerRadius="12"
                                            Opacity="{x:Bind CurrentDesktopHighlightOpacity, Mode=OneWay}" />
                                        <Grid Padding="6">
                                            <Border
                                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                                <Border
                                                    Margin="1"
                                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                    CornerRadius="6">
                                                    <Viewbox Stretch="Uniform">
                                                        <Grid
                                                            Width="{x:Bind PreviewCanvasWidth, Mode=OneWay}"
                                                            Height="{x:Bind PreviewCanvasHeight, Mode=OneWay}"
                                                            FlowDirection="LeftToRight">
                                                            <ItemsControl ItemsSource="{x:Bind PreviewWindowItems, Mode=OneWay}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <Canvas FlowDirection="LeftToRight" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="viewModels:NavigatorDesktopWindowItemViewModel">
                                                                        <Border
                                                                            Width="{x:Bind PreviewWidth, Mode=OneWay}"
                                                                            Height="{x:Bind PreviewHeight, Mode=OneWay}"
                                                                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                                            BorderBrush="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                                                                            BorderThickness="{x:Bind PreviewWindowBorderThickness, Mode=OneWay}"
                                                                            CornerRadius="{x:Bind PreviewWindowCornerRadius, Mode=OneWay}">
                                                                            <Border.RenderTransform>
                                                                                <TranslateTransform X="{x:Bind PreviewLeft, Mode=OneWay}" Y="{x:Bind PreviewTop, Mode=OneWay}" />
                                                                            </Border.RenderTransform>
                                                                            <Grid>
                                                                                <Border
                                                                                    Width="{x:Bind IconContainerSize, Mode=OneWay}"
                                                                                    Height="{x:Bind IconContainerSize, Mode=OneWay}"
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                                                    CornerRadius="8">
                                                                                    <Grid>
                                                                                        <Image
                                                                                            Margin="4"
                                                                                            Source="{x:Bind ApplicationIconImageSource, Mode=OneWay}"
                                                                                            Stretch="Uniform"
                                                                                            Visibility="{x:Bind ApplicationIconVisibility, Mode=OneWay}" />
                                                                                        <Viewbox Margin="4" Visibility="{x:Bind FallbackIconVisibility, Mode=OneWay}">
                                                                                            <SymbolIcon Symbol="AllApps" />
                                                                                        </Viewbox>
                                                                                    </Grid>
                                                                                </Border>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Grid>
                                                    </Viewbox>
                                                </Border>
                                            </Border>
                                        </Grid>
                                    </Grid>

                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                        Text="{x:Bind DisplayName, Mode=OneWay}"
                                        TextAlignment="Center"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</winuiex:WindowEx>
