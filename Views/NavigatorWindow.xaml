<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="DeskBorder.Views.NavigatorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:DeskBorder.ViewModels"
    xmlns:winuiex="using:WinUIEx"
    Title="DeskBorder Navigator"
    IsAlwaysOnTop="True"
    IsMaximizable="False"
    IsMinimizable="False"
    IsResizable="False"
    IsTitleBarVisible="False"
    IsVisibleInTray="False"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnEscapeKeyboardAcceleratorInvoked" />
        </Grid.KeyboardAccelerators>

        <Border
            Width="420"
            Padding="24"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="24">
            <StackPanel Spacing="20">
                <StackPanel Spacing="8">
                    <TextBlock
                        x:Name="NavigatorTitleTextBlock"
                        Style="{ThemeResource TitleTextBlockStyle}"
                        Text="Navigator" />
                    <TextBlock Text="{x:Bind ViewModel.InteractionStatusText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Border
                    Padding="12"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    CornerRadius="16">
                    <StackPanel Spacing="6">
                        <TextBlock
                            x:Name="TriggerAreaTitleTextBlock"
                            FontWeight="SemiBold"
                            Text="트리거 영역" />
                        <TextBlock Text="{x:Bind ViewModel.TriggerAreaDescription, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <ListView
                    x:Name="DesktopListView"
                    IsItemClickEnabled="True"
                    ItemClick="OnDesktopListViewItemClick"
                    ItemsSource="{x:Bind ViewModel.DesktopItems, Mode=OneWay}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:NavigatorDesktopItemViewModel">
                            <Grid Height="84">
                                <Border
                                    Width="4"
                                    HorizontalAlignment="Left"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="999"
                                    Opacity="{x:Bind CurrentDesktopHighlightOpacity, Mode=OneWay}" />

                                <Grid Padding="16,0,12,0" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Width="48"
                                        Height="48"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                        CornerRadius="16">
                                        <Viewbox>
                                            <SymbolIcon Symbol="{x:Bind IconSymbol, Mode=OneWay}" />
                                        </Viewbox>
                                    </Border>

                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName, Mode=OneWay}" />
                                        <TextBlock
                                            Opacity="0.72"
                                            Text="{x:Bind Description, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>

                                    <Border
                                        Grid.Column="2"
                                        Padding="10,4"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                        CornerRadius="999"
                                        Visibility="{x:Bind CurrentDesktopBadgeVisibility, Mode=OneWay}">
                                        <TextBlock Text="{x:Bind CurrentDesktopBadgeText, Mode=OneWay}" />
                                    </Border>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock
                    Opacity="0.72"
                    Text="{x:Bind ViewModel.LastRequestedDesktopDisplayText, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>
    </Grid>
</winuiex:WindowEx>
