<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="DeskBorder.Views.ToastWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winuiex="using:WinUIEx"
    Title="Toast"
    IsAlwaysOnTop="True"
    IsMaximizable="False"
    IsMinimizable="False"
    IsResizable="False"
    IsTitleBarVisible="False"
    IsVisibleInTray="False"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootGrid"
        VerticalAlignment="Center"
        Background="Transparent">
        <Grid Padding="16" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                FontSize="18"
                FontWeight="SemiBold"
                Text="{x:Bind ViewModel.Title, Mode=OneWay}" />

            <TextBlock
                Grid.Row="1"
                Text="{x:Bind ViewModel.Message, Mode=OneWay}"
                TextWrapping="WrapWholeWords" />

            <Button
                Grid.Row="2"
                HorizontalAlignment="Stretch"
                Click="OnActionButtonClicked"
                Content="{x:Bind ViewModel.ActionButtonText, Mode=OneWay}" />
        </Grid>
    </Grid>
</winuiex:WindowEx>
